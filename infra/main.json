              "properties": {
                "resource": {
                  "id": "allowance-db"
                }
              },
              "dependsOn": [
                "cosmosAccount"
              ]
            },
            "dbContainers": {
              "copy": {
                "name": "dbContainers",
                "count": "[length(variables('containerNames'))]"
