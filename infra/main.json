              "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
              "apiVersion": "2023-11-15",
              "name": "[format('{0}/{1}/{2}', parameters('accountName'), 'allowance-db', variables('containerNames')[copyIndex()])]",
              "properties": {
                "resource": {
                  "id": "[variables('containerNames')[copyIndex()]]",
                  "partitionKey": {
                    "paths": [
                      "/familyId"
                    ],
                    "kind": "Hash",
                    "version": 2
                  },
                  "indexingPolicy": {
                    "indexingMode": "consistent",
                    "automatic": true,
                    "includedPaths": [
                      {
                        "path": "/*"
                      }
                    ],
                    "excludedPaths": [
                      {
                        "path": "/\"_etag\"/?"
                      }
                    ]
                  }
                }
              },
              "dependsOn": [
                "database"
              ]
            }
